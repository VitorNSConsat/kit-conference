# Copie este arquivo para .env e ajuste os valores antes de iniciar

# Chave secreta para sessões — gere uma string aleatória longa
SECRET_KEY=troque-por-chave-aleatoria-longa

# Nome da empresa exibido na etiqueta impressa
EMPRESA_NOME=Nome da Empresa

# Caminho do banco de dados (padrão: na pasta do projeto)
DB_PATH=kit_conference.db
